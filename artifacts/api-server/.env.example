# 로컬 개발 시작 방법:
#   Mac/Linux:  cp .env.example .env
#   Windows:    copy .env.example .env
# 복사 후 아래 값을 채워주세요.

# OpenAI API
OPENAI_API_KEY=

# Database (Neon PostgreSQL)
NEON_DATABASE_URL=

# RAG 설정 (선택 - 기본값 사용 가능)
RAG_TOP_K=5
EMBEDDING_MODEL=text-embedding-3-small
CHAT_MODEL=gpt-4o-mini

# Server (로컬 기본값: 3000)
PORT=3000
